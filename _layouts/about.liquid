---
layout: default
---
<div class="post">
  <article>
    <div class="row">
      <!-- Left column: profile -->
      <div class="col-md-3 pr-4">
        {% if page.profile %}
          <div class="profile text-center" style="margin: 0 auto;">
            {% if page.profile.image %}
              {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
              {% if page.profile.image_circular %}
                {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
              {% else %}
                {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
              {% endif %}
              {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px) 30vw, 95vw"{% endcapture %}
              {%
                include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
                cache_bust=true
              %}
            {% endif %}
            {% if page.profile.more_info and page.profile.more_info != false %}
              <div class="more-info">{{ page.profile.more_info }}</div>
            {% endif %}
          </div>
        {% endif %}

        <p class="text-center mt-2" style="font-weight: 700; font-size: 0.9rem;">
          Interaction Designer<br>
          HCI Researcher
        </p>
        <p class="text-center desc mt-1">{{ page.subtitle }}</p>

        <!-- Social -->
        {% if page.social %}
          <div class="social text-center mt-3">
            <div class="contact-icons">{% social_links %}</div>
            <div class="contact-note">{{ site.contact_note }}</div>
          </div>
        {% endif %}

        <!-- Academic Service -->
        <hr class="mt-4 mb-2">
        <div class="sidebar-section text-left">
          <h6 style="font-weight: 700; font-size: 0.75rem;">Academic Service</h6>
          <ul class="sidebar-marker-list" style="padding-left: 0; margin-bottom: 0; font-size: 0.75rem; list-style: none;">
            <li>Reviewer, <strong>CHI 2026 Papers</strong> — <svg class="hand-star-icon" width="12" height="12" viewBox="0 0 24 24" style="display:inline-block;vertical-align:-1px;margin-right:2px;"><path d="M12 2.5c.4 0 .7.2.9.6l2.5 5.2 5.7.8c.4.1.7.3.8.7.1.4 0 .7-.3 1l-4.1 4 1 5.6c.1.4 0 .7-.3.9-.3.2-.7.3-1 .1L12 18.8l-5.1 2.7c-.4.2-.7.1-1-.1-.3-.2-.4-.6-.3-.9l1-5.6-4.1-4c-.3-.3-.4-.7-.3-1 .1-.4.4-.6.8-.7l5.7-.8 2.5-5.2c.2-.4.5-.6.9-.6z" fill="#e63946" stroke="#c1121f" stroke-width="0.5"/></svg><em>Outstanding Reviews</em></li>
            <li>Reviewer, <strong>CHI 2026 Posters</strong></li>
            <li>Reviewer, <strong>CHI 2025 Late Breaking Work</strong></li>
            <li>Reviewer, <strong>HRI 2025 Late Breaking Reports</strong></li>
          </ul>
        </div>

        <!-- Teaching -->
        <hr class="mt-2 mb-2">
        <div class="sidebar-section text-left">
          <h6 style="font-weight: 700; font-size: 0.75rem;">Teaching</h6>
          <ul class="sidebar-marker-list sidebar-marker-list-purple" style="padding-left: 0; margin-bottom: 0; font-size: 0.75rem; list-style: none;">
            <li>2026 <strong>Guest Speaker</strong>, <em>Interaction Design</em> (UG), Tongji — "Understanding OpenClaw from an Interaction Design Perspective"</li>
            <li>2025 <strong>Guest Speaker</strong>, DS323 <em>AI in Design</em>, SUSTech — "Prototyping LLM-Powered Interactive Systems"</li>
            <li>2025 <strong>Guest Speaker</strong>, <em>Interaction Design</em> (UG), Tongji — "LLM Interaction Design"</li>
            <li>2024 <strong>Guest Speaker</strong>, <em>Interaction Design</em> (Grad), Tongji — "Human-Robot Interaction Design"</li>
            <li>2024 <strong>Guest Speaker</strong>, <em>Interaction Design</em> (Grad), Tongji — "XR and Interaction Design"</li>
            <li>2023 <strong>TA</strong>, <em>Interaction Design</em> (UG), Tongji</li>
            <li>2022 <strong>TA</strong>, <em>Interaction Design</em> (Grad), Tongji</li>
            <li>2022 <strong>TA</strong>, <em>HCI Product &amp; System Design</em> (Grad), Tongji</li>
            <li>2022 <strong>TA</strong>, <em>Interaction Design Studio 1</em> (Grad), Tongji — Industrial Digital Twin</li>
            <li>2021 <strong>TA</strong>, <em>Interaction Design</em> (Grad), Tongji</li>
            <li>2021 <strong>TA</strong>, <em>HCI Product &amp; System Design</em> (Grad), Tongji</li>
            <li>2021 <strong>Technical Mentor</strong>, <em>Interaction Design Studio 1</em> (Grad), Tongji — Unity Development</li>
            <li>2021 <strong>Technical Mentor</strong>, <em>Interaction Design Studio 2</em> (Grad), Tongji — Unity AR Development</li>
            <li>2020 <strong>TA</strong>, <em>Interaction Design</em> (Grad), Tongji</li>
            <li>2019 <strong>TA</strong>, <em>Interaction Design</em> (Grad), Tongji</li>
            <li>2018 <strong>TA</strong>, <em>Interaction Design</em> (Grad), Tongji</li>
          </ul>
        </div>
      </div>

      <!-- Right column: name + bio + selected publications + projects -->
      <div class="col-md-9 pl-5">
        <div class="name-annotation">
          <span class="name-main">葛亚特</span>
          <svg class="name-connector" viewBox="0 0 120 40">
            <path d="M2,28 Q60,5 112,16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M104,11 L112,16 L104,21" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="name-eng">Yate Ge</span>
        </div>
        <div class="about-bio mb-3">{{ content }}</div>

        <h2 class="marker-highlight mt-5">
          <a href="{{ '/publications/' | relative_url }}" style="color: inherit">publications</a>
        </h2>
        <div class="publications about-publications">
          {% bibliography %}
        </div>

        {% assign sorted_projects = site.projects | sort: 'importance' %}
        {% if sorted_projects.size > 0 %}
          <div class="projects">
            <h2 class="mt-6 marker-highlight marker-green" style="margin-top: 4rem !important;">
              <a href="{{ '/projects/' | relative_url }}" style="color: inherit">projects</a>
            </h2>
            <div class="row row-cols-1 mt-3">
              {% for project in sorted_projects %}
                {% include projects_horizontal.liquid plain=true %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
